{
  "name": "alutic-ai",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "gen": "esbuild src/data/pilots.ts --bundle --format=esm --platform=node --outfile=server/pilots.gen.mjs",
    "dev": "npm run gen && concurrently -k -n web,api -c green,blue \"vite\" \"node server/index.js\"",
    "server": "npm run gen && node server/index.js",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 4173",
    "start": "npm run gen && npm run build && node server/index.js"
  },
  "dependencies": {
    "@solana/web3.js": "^1.98.4",
    "bs58": "^6.0.0",
    "concurrently": "^10.0.3",
    "express": "^5.2.1",
    "framer-motion": "^11.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.5"
  }
}
